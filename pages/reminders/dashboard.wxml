<view class="page">
  <view class="overview" data-tab="all" bindtap="navigateToList" hover-class="card-hover">
    <view>
      <text class="overview-label">配置总数</text>
      <text class="overview-num">{{totalCount}}</text>
    </view>
    <view class="overview-action">
      <text>查看列表</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="stat-grid">
    <view wx:for="{{statCards}}" wx:key="label" class="stat-card {{item.tone}}" data-tab="{{item.tab}}" data-filter="{{item.filter}}" bindtap="navigateToList" hover-class="card-hover">
      <text class="stat-name">{{item.label}}</text>
      <text class="stat-num">{{item.value}}</text>
      <text class="stat-desc">{{item.desc}}</text>
    </view>
  </view>

  <view class="section-head">
    <view>
      <text class="section-title">提醒类型</text>
    </view>
  </view>

  <view class="type-grid">
    <view wx:for="{{typeCards}}" wx:key="label" class="type-card {{item.tone}}" data-tab="{{item.tab}}" data-filter="{{item.filter}}" bindtap="navigateToList" hover-class="card-hover">
      <view>
        <text class="type-name">{{item.label}}</text>
        <text class="type-desc">{{item.desc}}</text>
      </view>
      <text class="type-num">{{item.value}}</text>
    </view>
  </view>

  <view class="section-head">
    <view>
      <text class="section-title">系统</text>
    </view>
  </view>

  <view class="module-card" bindtap="navigateToLogs" hover-class="card-hover">
    <view>
      <text class="module-name">系统日志</text>
      <text class="module-desc">实时查看运行日志</text>
    </view>
    <text class="module-action">查看</text>
  </view>

  <view class="section-head">
    <view>
      <text class="section-title">最近配置</text>
    </view>
  </view>

  <view class="recent-list">
    <view wx:if="{{!recentReminders.length}}" class="empty" data-tab="all" bindtap="navigateToList">
      <text>暂无配置</text>
    </view>
    <view wx:for="{{recentReminders}}" wx:key="id" class="recent-item" data-tab="all" bindtap="navigateToList" hover-class="card-hover">
      <view class="recent-main">
        <text class="recent-title">{{item.title}}</text>
        <text class="recent-summary">{{item.summary}}</text>
      </view>
      <view class="recent-meta">
        <text>{{item.typeLabel}}</text>
        <text>{{item.statusText}}</text>
      </view>
    </view>
  </view>
</view>
