.page,
page {
  height: 100vh;
  overflow: hidden;
}

.page {
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  min-height: 0;
  padding: 20rpx 20rpx 28rpx;
  background: #f4f7fb;
}

.control-panel {
  box-sizing: border-box;
  flex: 0 0 auto;
  padding: 16rpx;
  border: 1rpx solid #dbe5f5;
  border-radius: 12rpx;
  background: #ffffff;
}

.level-scroll {
  display: flex;
  white-space: nowrap;
}

.level {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  min-width: 96rpx;
  margin-right: 10rpx;
  padding: 0 20rpx;
  border-radius: 28rpx;
  background: #f0f4f2;
  color: #58685f;
  font-size: 23rpx;
  line-height: 1;
}

.level.active {
  background: #2563eb;
  color: #ffffff;
  font-weight: 700;
}

.level-hover {
  opacity: 0.78;
}

.actions {
  display: flex;
  align-items: center;
  margin-top: 14rpx;
}

.status,
.action {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 58rpx;
  border-radius: 29rpx;
  font-size: 23rpx;
  font-weight: 700;
}

.status {
  flex: 1;
  min-width: 0;
}

.status.live {
  background: #dbeafe;
  color: #1d4ed8;
}

.status.paused {
  background: #f0f4f2;
  color: #68766d;
}

.action {
  flex: 0 0 112rpx;
  margin-left: 10rpx;
  background: #eef4ff;
  color: #2563eb;
}

.action.muted {
  background: #f0f4f2;
  color: #46534b;
}

.time-panel {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid #edf1ee;
}

.time-filter-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 10rpx;
}

.time-picker {
  display: block;
  min-width: 0;
}

.time-filter {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  height: 58rpx;
  padding: 0 18rpx;
  border-radius: 29rpx;
  background: #f0f4f2;
  color: #58685f;
}

.time-filter.active {
  background: #eef4ff;
  color: #2563eb;
  font-weight: 700;
}

.time-value {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time-value {
  max-width: 100%;
  font-size: 23rpx;
  line-height: 1;
}

.clear-time {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 54rpx;
  margin-top: 10rpx;
  border-radius: 27rpx;
  background: #f0f4f2;
  color: #46534b;
  font-size: 22rpx;
  font-weight: 700;
}

.terminal {
  box-sizing: border-box;
  flex: 1;
  min-height: 0;
  height: 0;
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #0f172a;
  color: #dbeafe;
  font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
}

.empty {
  padding: 80rpx 20rpx;
  color: rgba(216, 243, 223, 0.62);
  font-size: 24rpx;
  text-align: center;
}

.log-row {
  padding: 12rpx 0 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.log-head {
  display: flex;
  align-items: center;
  min-width: 0;
}

.log-time,
.log-level,
.log-logger {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.log-time {
  flex: 0 0 260rpx;
  color: #8aa395;
  font-size: 19rpx;
}

.log-level {
  flex: 0 0 82rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.log-logger {
  flex: 1;
  min-width: 0;
  color: #9bb2a4;
  font-size: 19rpx;
}

.log-message {
  display: block;
  margin-top: 8rpx;
  white-space: pre-wrap;
  word-break: break-all;
}

.log-message {
  color: #dbeafe;
  font-size: 22rpx;
  line-height: 1.45;
}

.stack-panel {
  box-sizing: border-box;
  margin-top: 12rpx;
  padding: 14rpx;
  border: 1rpx solid rgba(248, 113, 113, 0.34);
  border-radius: 10rpx;
  background: rgba(127, 29, 29, 0.22);
}

.stack-title {
  display: block;
  margin-bottom: 10rpx;
  color: #fecaca;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.2;
}

.log-throwable {
  display: block;
  color: #fee2e2;
  font-size: 20rpx;
  line-height: 1.55;
  white-space: pre-wrap;
  word-break: break-all;
}

.log-row.info .log-level {
  color: #93c5fd;
}

.log-row.warn .log-level {
  color: #fbbf24;
}

.log-row.error .log-level {
  color: #fb7185;
}

.log-row.debug .log-level {
  color: #a7f3d0;
}

.bottom-anchor {
  height: 1rpx;
}
