.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 24rpx 24rpx 190rpx;
  background: #f4f7fb;
}

.reminder,
.empty {
  border: 1rpx solid #dbe5f5;
  border-radius: 12rpx;
  background: #ffffff;
}

.tabs {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  width: 100%;
}

.tab {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 68rpx;
  min-width: 0;
  border-radius: 34rpx;
  background: #f2f5f3;
  color: #607066;
  font-size: 25rpx;
  line-height: 1;
}

.tab.active {
  background: #2563eb;
  color: #ffffff;
  font-weight: 700;
}

.tab-hover {
  background: #eff6ff;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.empty {
  padding: 30rpx;
  color: #7b8780;
  font-size: 24rpx;
  text-align: center;
}

.reminder {
  position: relative;
  overflow: hidden;
  padding: 0;
}

.swipe-content {
  position: relative;
  z-index: 1;
  box-sizing: border-box;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #ffffff;
  transform: translateX(0);
  transition: transform 0.18s ease;
}

.reminder.swiped .swipe-content {
  transform: translateX(-360rpx);
}

.swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  display: flex;
  width: 360rpx;
}

.swipe-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 100%;
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: #2563eb;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
}

.swipe-button::after {
  border: 0;
}

.swipe-button.edit {
  background: #2563eb;
}

.swipe-button.danger {
  background: #dc2626;
}

.swipe-button.toggle-enable {
  background: #16a34a;
}

.swipe-button.toggle-disable {
  background: #f59e0b;
}

.reminder-body {
  display: flex;
  align-items: center;
  min-width: 0;
}

.avatar {
  display: flex;
  flex: 0 0 60rpx;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  margin-right: 14rpx;
  border-radius: 30rpx;
  background: #dbeafe;
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 700;
}

.reminder-content {
  flex: 1;
  min-width: 0;
}

.reminder-line {
  display: flex;
  align-items: center;
  min-width: 0;
}

.reminder-title {
  flex: 1;
  overflow: hidden;
  color: #17211b;
  font-size: 28rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.badge {
  flex: 0 0 auto;
  margin-left: 12rpx;
  padding: 5rpx 12rpx;
  border-radius: 18rpx;
  font-size: 20rpx;
  line-height: 1.2;
}

.badge.is-on {
  background: #dbeafe;
  color: #1d4ed8;
}

.badge.is-off {
  background: #f0f3f1;
  color: #7b8780;
}

.summary,
.meta {
  display: block;
  overflow: hidden;
  margin-top: 8rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.summary {
  color: #3f4d45;
  font-size: 24rpx;
}

.meta {
  color: #87938b;
  font-size: 21rpx;
}

.actions {
  display: none;
}

.link-button {
  margin: 0 0 0 20rpx;
  padding: 0;
  background: transparent;
  color: #2563eb;
  font-size: 24rpx;
  line-height: 40rpx;
}

.link-button.danger {
  color: #dc2626;
}

.fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(128rpx + env(safe-area-inset-bottom));
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 94rpx;
  height: 94rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.55);
  border-radius: 50%;
  background: rgba(37, 99, 235, 0.86);
  box-shadow: 0 16rpx 34rpx rgba(37, 99, 235, 0.26);
  color: #ffffff;
  backdrop-filter: blur(12rpx);
}

.fab-hover {
  opacity: 0.82;
}

.fab-plus {
  font-size: 54rpx;
  font-weight: 700;
  line-height: 1;
}

.bottom-filter {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 18;
  box-sizing: border-box;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(219, 229, 245, 0.96);
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(14rpx);
}

.loading-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 50;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(244, 247, 251, 0.88);
  backdrop-filter: blur(8rpx);
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 5rpx solid #dbe5f5;
  border-top-color: #2563eb;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 18rpx;
  color: #475569;
  font-size: 24rpx;
  font-weight: 600;
}
